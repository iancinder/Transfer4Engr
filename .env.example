# Copy this file to .env.local and paste your real keys.
#
# ---------------------------------------------------------------------------
# Form submissions
# ---------------------------------------------------------------------------
# Get the key from https://web3forms.com — register with
# iansendelbach@gmail.com so form submissions are emailed there.
NEXT_PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_ACCESS_KEY_HERE

# ---------------------------------------------------------------------------
# Keystatic (blog editor at /keystatic)
# ---------------------------------------------------------------------------
# Local development needs NONE of these — Keystatic writes directly to the
# working tree. They are required only in Vercel, to let the deployed editor
# commit posts to GitHub.
#
# Generated for you by running `npx keystatic create-github-app` (see README).
# Until NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG is set, the deployed editor
# falls back to local mode, which cannot save on Vercel's read-only filesystem.
#
# NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=transfer4engr-content
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=

# ---------------------------------------------------------------------------
# Canonical origin (optional)
# ---------------------------------------------------------------------------
# Defaults to https://transfer4engr.com. Override only for preview builds that
# should describe themselves with their own URL.
# NEXT_PUBLIC_SITE_URL=
